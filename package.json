{
  "name": "neotavern-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "An experimental frontend for SillyTavern",
  "license": "AGPL-3.0",
  "author": "bmen25124",
  "type": "module",
  "scripts": {
    "start": "node launcher.js",
    "i18n": "node manage-i18n.js",
    "i18n:remove": "node manage-i18n.js --remove",
    "dev": "npm run i18n && vite",
    "build:types": "vite build --config vite.config.types.ts",
    "build": "npm run i18n && vue-tsc --noEmit && vite build",
    "build:profile": "node scripts/build-profile.js",
    "build:deploy": "vite build",
    "preview": "vite preview",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@floating-ui/vue": "^2.0.0",
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "ajv": "^8.17.1",
    "bowser": "^2.14.1",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "dompurify": "^3.3.0",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.3",
    "handlebars": "^4.7.8",
    "highlight.js": "^11.11.1",
    "http-proxy-middleware": "^4.1.1",
    "js-yaml": "^5.2.1",
    "jsep": "^1.4.0",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "vue": "^3.4.31",
    "vue-i18n": "^11.4.6",
    "yaml": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.9",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "7.2.2",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "minimatch@5.1.9": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "2.0.3"
    }
  },
  "engines": {
    "node": ">=22.13"
  }
}
